#!/usr/bin/env bash
# fleet — thin launcher that runs the TS CLI via tsx (no build step).
# Resolves through symlinks so it works when linked onto PATH (e.g. ~/.local/bin).
set -euo pipefail
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
HERE="$(cd -P "$(dirname "$SOURCE")/.." >/dev/null 2>&1 && pwd)"

# ── Auto-update (best-effort, never blocks the real command) ────────────────
# Track main automatically: at most once/24h, only on a clean `main`, ff-only,
# bounded network time. ANY failure (offline, dirty, diverged, npm) degrades to
# running the user's command on existing code. The only thing this ever writes
# is a one-line notice on stderr (stdout stays clean for piping/parsing); all
# git/npm chatter is suppressed. Opt out with FLEET_NO_AUTOUPDATE=1.
__fleet_autoupdate() {
  set +e +o pipefail            # local to this subshell — never let update break the run
  local repo="$1"
  local stamp="${HOME}/.fleet/autoupdate-stamp"

  cd "$repo" >/dev/null 2>&1 || return 0
  git rev-parse --is-inside-work-tree >/dev/null 2>&1 || return 0

  # Throttle: skip if we already checked within the last 24h (1440 min). The
  # stamp is touched up front so an offline run still counts as "checked" and
  # we don't retry-storm on every invocation.
  if [ -f "$stamp" ] && [ -z "$(find "$stamp" -mmin +1440 2>/dev/null)" ]; then
    return 0
  fi
  mkdir -p "${HOME}/.fleet" >/dev/null 2>&1
  : > "$stamp" 2>/dev/null

  # Only auto-update a clean checkout sitting on main — developers on a feature
  # branch or with local edits are exempt automatically.
  [ "$(git rev-parse --abbrev-ref HEAD 2>/dev/null)" = "main" ] || return 0
  [ -z "$(git status --porcelain 2>/dev/null)" ] || return 0

  # Bounded fetch: abort if the transfer stalls under 1KB/s for 5s.
  GIT_HTTP_LOW_SPEED_LIMIT=1000 GIT_HTTP_LOW_SPEED_TIME=5 \
    git fetch --quiet origin main >/dev/null 2>&1 || return 0

  local old new
  old="$(git rev-parse HEAD 2>/dev/null)" || return 0
  # Only fast-forward: HEAD must be an ancestor of origin/main, and behind it.
  git merge-base --is-ancestor HEAD origin/main >/dev/null 2>&1 || return 0
  [ "$old" != "$(git rev-parse origin/main 2>/dev/null)" ] || return 0

  git pull --ff-only --quiet origin main >/dev/null 2>&1 || return 0
  new="$(git rev-parse HEAD 2>/dev/null)" || return 0
  [ "$old" != "$new" ] || return 0

  # Reinstall deps only when the lockfile actually moved in the pull. If that
  # install fails, roll the pull back to the pre-pull sha so we never exec new
  # code against stale node_modules — the user's command runs on the consistent
  # old checkout instead, and the update is retried next window / via `fleet update`.
  if ! git diff --quiet "$old" "$new" -- package-lock.json >/dev/null 2>&1; then
    if ! npm ci --silent >/dev/null 2>&1; then
      git reset --hard "$old" >/dev/null 2>&1
      echo "fleet: update deferred: dep install failed (rolled back to ${old:0:7}) — run \`fleet update\` to retry" >&2
      return 0
    fi
  fi
  echo "fleet updated → ${new:0:7}" >&2
}

if [ "${FLEET_NO_AUTOUPDATE:-}" != "1" ]; then
  ( __fleet_autoupdate "$HERE" ) || true
fi

exec "$HERE/node_modules/.bin/tsx" "$HERE/src/cli.ts" "$@"
